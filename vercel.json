{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "public/index.html", "use": "@vercel/static" },
    { "src": "public/logo.png", "use": "@vercel/static" },
    { "src": "public/badge.png", "use": "@vercel/static" },
    { "src": "public/manifest.json", "use": "@vercel/static" },
    { "src": "public/sw.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/logo.png", "dest": "/public/logo.png" },
    { "src": "/badge.png", "dest": "/public/badge.png" },
    { "src": "/manifest.json", "dest": "/public/manifest.json" },
    { "src": "/sw.js", "dest": "/public/sw.js" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
